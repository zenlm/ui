{
  "name": "@zenlm/ui",
  "version": "1.0.4",
  "description": "React components for the Zen LM model library — model cards, tables, and browsable catalog",
  "keywords": [
    "ai",
    "llm",
    "models",
    "zen",
    "zenlm",
    "react",
    "components"
  ],
  "license": "MIT",
  "author": "Zen LM",
  "homepage": "https://zenlm.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/zenlm/ui"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "publish:npm": "npm publish --access public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@zenlm/models": "^1.0.2",
    "glob": "^13.0.6",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
